rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Admin check: looks up /admins/{email} in Firestore. This mirrors the
    // ADMIN_EMAILS allowlist in index.js — keep both in sync. Storage rules
    // can't read arbitrary constants from Cloud Functions, so the email
    // also needs a doc at admins/{your-email} with any field (e.g. {ok:true})
    // created once via the Firebase Console. See the setup guide.
    function isAdmin() {
      return request.auth != null && request.auth.token.email != null &&
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.token.email));
    }

    // ── gallery images ─────────────────────────────────────────────────
    // Public read (these appear on gallery.html). Only admins can upload.
    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ── order progress photos ──────────────────────────────────────────
    // Uploaded by admin (workshop staff) as an order moves through
    // production. Only the order's owner can read their own progress
    // photos; admin can read/write any.
    match /orders/{orderId}/progress/{allPaths=**} {
      allow read: if request.auth != null && (
        isAdmin() ||
        firestore.get(/databases/(default)/documents/orders/$(orderId)).data.user_uid == request.auth.uid
      );
      allow write: if isAdmin()
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ── customization studio draft previews ────────────────────────────
    // Each draft owner can upload/read their own draft preview snapshot.
    // Public read so shared draft links render for anonymous visitors.
    match /drafts/{draftId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 4 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Default deny.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
