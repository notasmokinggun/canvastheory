rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin check: looks up /admins/{email}. Mirrors ADMIN_EMAILS in
    // index.js and the same function in storage.rules — keep all three in
    // sync. Create a doc at admins/{your-email} (any field, e.g. {ok:true})
    // once via the Firebase Console. See the setup guide.
    function isAdmin() {
      return request.auth != null && request.auth.token.email != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // ── admins ─────────────────────────────────────────────────────────
    // Allowlist of admin emails, used only as a lookup table by isAdmin().
    // No client read/write — managed by you directly in the console.
    match /admins/{email} {
      allow read, write: if false;
    }

    // ── users ──────────────────────────────────────────────────────────
    // Each user can only read/write their own document. Created by the
    // client's signInWithGoogle() flow (see auth.js in the README).
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── orders ─────────────────────────────────────────────────────────
    // Orders are created ONLY by the createOrder Cloud Function (which
    // runs with admin privileges and bypasses these rules entirely), so
    // client-side `create` is intentionally disallowed here — it would
    // let someone write an order doc with a fake amount_paise. Reads are
    // restricted to the order's owner. Updates and deletes are never
    // allowed from the client — only the webhook and the admin-only
    // updateOrderStatus / addProgressPhoto Cloud Functions (also
    // admin-privileged, gated by ADMIN_EMAILS in index.js) can change
    // order status. The admin page (admin.html) never writes to
    // Firestore directly — it only calls those callables.
    match /orders/{orderId} {
      allow create: if false;
      allow read: if request.auth != null
        && resource.data.user_uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── gallery ────────────────────────────────────────────────────────
    // Public read for the gallery.html browsing experience. Writes
    // restricted to admin accounts (see isAdmin() above).
    match /gallery/{designId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── drafts ─────────────────────────────────────────────────────────
    // Customization Studio drafts. Public read because share links must
    // work for anonymous visitors. Only the owner can create or update
    // their own draft. Anonymous (no-auth) drafts are intentionally not
    // supported here — require sign-in before saving a draft so it can
    // be tied to a user.
    match /drafts/{draftId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.user_uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.user_uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.user_uid == request.auth.uid;
    }

    // ── referral_credits ───────────────────────────────────────────────
    // Written only by the webhook (admin-privileged). Owners can read
    // their own credit history.
    match /referral_credits/{creditId} {
      allow read: if request.auth != null
        && resource.data.referrer_uid == request.auth.uid;
      allow write: if false;
    }

    // ── stats ──────────────────────────────────────────────────────────
    // Denormalized counters for admin dashboards. No client access.
    match /stats/{doc} {
      allow read, write: if false;
    }

    // Default deny — anything not matched above is inaccessible.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
